// prisma/schema.prisma
// Database schema for Alphatech Computer Engineering & Technologies

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────
// USERS & AUTH
// ──────────────────────────────

enum Role {
  CUSTOMER
  TECHNICIAN
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  repairs      Repair[]       @relation("CustomerRepairs")
  assignedRepairs Repair[]    @relation("TechnicianRepairs")
  appointments Appointment[]
  reviews      Review[]
  messages     Message[]
  blogPosts    BlogPost[]
}

// ──────────────────────────────
// CATALOG
// ──────────────────────────────

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToSubcategory")
  products Product[]
}

enum ProductCondition {
  NEW
  REFURBISHED
  CUSTOM
}

model Product {
  id               String           @id @default(cuid())
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  name             String
  slug             String           @unique
  description      String
  price            Int // stored in Naira (kobo-free integer) to avoid float rounding issues
  compareAtPrice   Int?
  condition        ProductCondition @default(NEW)
  brand            String?
  sku              String?          @unique
  stockQuantity    Int              @default(0)
  images           String[]
  specs            Json?
  isFeatured       Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  orderItems       OrderItem[]
  reviews          Review[]
}

// ──────────────────────────────
// ORDERS & PAYMENTS
// ──────────────────────────────

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  status          OrderStatus @default(PENDING)
  subtotal        Int
  discount        Int         @default(0)
  total           Int
  shippingAddress Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           OrderItem[]
  payments        Payment[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id         String          @id @default(cuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id])
  provider   PaymentProvider
  reference  String          @unique
  amount     Int
  status     PaymentStatus   @default(PENDING)
  paidAt     DateTime?
  createdAt  DateTime        @default(now())
}

// ──────────────────────────────
// REPAIRS & APPOINTMENTS
// ──────────────────────────────

enum RepairStatus {
  RECEIVED
  DIAGNOSING
  AWAITING_PARTS
  REPAIRING
  READY
  COMPLETED
  CANCELLED
}

model Repair {
  id                String       @id @default(cuid())
  ticketNumber      String       @unique
  userId            String?
  user              User?        @relation("CustomerRepairs", fields: [userId], references: [id])
  technicianId      String?
  technician        User?        @relation("TechnicianRepairs", fields: [technicianId], references: [id])
  deviceType        String
  brandModel        String?
  problemDescription String
  photos            String[]
  status            RepairStatus @default(RECEIVED)
  estimatedCost     Int?
  finalCost         Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

enum AppointmentType {
  REPAIR_DROPOFF
  CONSULTATION
  BUSINESS_IT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Appointment {
  id             String             @id @default(cuid())
  userId         String?
  user           User?              @relation(fields: [userId], references: [id])
  type           AppointmentType
  preferredDate  DateTime
  preferredTime  String
  status         AppointmentStatus  @default(PENDING)
  notes          String?
  createdAt      DateTime           @default(now())
}

// ──────────────────────────────
// REVIEWS, MESSAGES, BLOG, COUPONS
// ──────────────────────────────

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

enum MessageStatus {
  OPEN
  RESOLVED
}

model Message {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  name      String
  email     String
  subject   String?
  message   String
  status    MessageStatus @default(OPEN)
  createdAt DateTime      @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  coverImage  String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  tags        String[]
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  discountType DiscountType
  value       Int
  expiresAt   DateTime?
  usageLimit  Int?
  timesUsed   Int          @default(0)
}

// ──────────────────────────────
// SITE SETTINGS (admin editable)
// ──────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
