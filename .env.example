# Copy this file to .env.local and fill in real values.
# .env.local is already in .gitignore — it will never be committed or shared.

# From Neon: project dashboard → Connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Used to sign login sessions. Any long random string works for local dev.
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Used once by `npx prisma db seed` to create your first admin account.
ADMIN_NAME="Alphatech Admin"
ADMIN_EMAIL="admin@alphatech.ng"
ADMIN_PASSWORD="choose-a-strong-password"

# Cloudinary — for product image and logo uploads (free account at cloudinary.com)
# Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
